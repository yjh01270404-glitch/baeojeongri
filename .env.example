# 네이버 개발자 센터에서 발급 (https://developers.naver.com)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 카카오 소셜 로그인 개발자 센터에서 발급
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# NextAuth / Auth.js (openssl rand -base64 32 로 생성 권장)
AUTH_SECRET=
# 로컬: http://localhost:3000 / 배포: https://riderjeongbibi.vercel.app (Vercel 프로젝트·커스텀 도메인에 맞게 수정)
NEXTAUTH_URL=http://localhost:3000

# 카카오맵 JavaScript 키 (장소 검색·지도)
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=

# 카카오 REST API 키 (서버에서 Static Map 이미지 프록시용)
KAKAO_REST_API_KEY=
